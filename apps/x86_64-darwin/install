#!/usr/bin/env bash
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

_print() { echo -e "$1"; }
_step()  { echo -e "\n${YELLOW}==> $1${NC}"; }
_ok()    { echo -e "${GREEN}✓ $1${NC}"; }
_err()   { echo -e "${RED}✗ $1${NC}"; exit 1; }

# ── Guard: macOS only ────────────────────────────────────────────────────────
if [[ "$(uname)" != "Darwin" ]]; then
  _err "This script is for macOS only."
fi

# ── Detect architecture ──────────────────────────────────────────────────────
case "$(uname -m)" in
  arm64)  ARCH="aarch64-darwin" ;;
  x86_64) ARCH="x86_64-darwin" ;;
  *)      _err "Unsupported architecture: $(uname -m)" ;;
esac

_print "${GREEN}Starting fresh Mac bootstrap (${ARCH})…${NC}"

# ── Step 1: Xcode Command Line Tools ────────────────────────────────────────
_step "Step 1/6 — Xcode Command Line Tools"
if xcode-select -p &>/dev/null; then
  _ok "Xcode Command Line Tools already installed at $(xcode-select -p)"
else
  _print "Installing Xcode Command Line Tools unattended via softwareupdate…"
  touch /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
  XCLT_PKG=$(softwareupdate -l 2>/dev/null \
    | awk '/\*.*Command Line Tools for Xcode/ { $1=$1; print }' \
    | tail -1 \
    | sed 's/^[[:space:]]*\* //')
  if [[ -z "$XCLT_PKG" ]]; then
    rm -f /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
    _err "Could not find Xcode Command Line Tools in softwareupdate catalog. Run 'softwareupdate -l' to check availability."
  fi
  _print "Found package: $XCLT_PKG"
  softwareupdate -i "$XCLT_PKG" --verbose
  rm -f /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
  _ok "Xcode Command Line Tools installed"
fi

# ── Step 2: Determinate Nix ─────────────────────────────────────────────────
_step "Step 2/6 — Determinate Nix"
if command -v nix &>/dev/null; then
  _ok "Nix already installed: $(nix --version)"
else
  _print "Installing Determinate Nix…"
  curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix \
    | sh -s -- install
  _ok "Determinate Nix installed"
fi

# ── Source Nix environment ───────────────────────────────────────────────────
NIX_PROFILE="/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh"
if [[ -f "$NIX_PROFILE" ]]; then
  # shellcheck source=/dev/null
  . "$NIX_PROFILE"
fi

if ! command -v nix &>/dev/null; then
  _err "Nix is not on PATH after sourcing the profile. Please open a new terminal and re-run this script."
fi

# ── Step 3: Clone config repository ─────────────────────────────────────────
_step "Step 3/6 — Clone config repository"
DEFAULT_DEST="$HOME/Developer/nixos-config"
_print "Where should the config be cloned? [${DEFAULT_DEST}]: "
read -r DEST
DEST="${DEST:-$DEFAULT_DEST}"

if [[ -d "$DEST/.git" ]]; then
  _ok "Repo already present at $DEST — skipping clone"
else
  mkdir -p "$(dirname "$DEST")"
  git clone git@github.com:mrbruins/.nixos-config.git "$DEST"
  _ok "Cloned to $DEST"
fi

cd "$DEST"

# ── Step 4: Apply user configuration ────────────────────────────────────────
_step "Step 4/6 — Apply user configuration (username, email, secrets repo)"
bash "./apps/${ARCH}/apply"

# ── Step 5: SSH keys ─────────────────────────────────────────────────────────
_step "Step 5/6 — SSH keys"
_print "Do you want to (c)reate new SSH keys or (u)se existing keys from a USB drive? [c/u, default: c]: "
read -r KEY_CHOICE
KEY_CHOICE="${KEY_CHOICE:-c}"

if [[ "$KEY_CHOICE" =~ ^[Cc]$ ]]; then
  bash "./apps/${ARCH}/create-keys"
elif [[ "$KEY_CHOICE" =~ ^[Uu]$ ]]; then
  bash "./apps/${ARCH}/copy-keys"
else
  _print "${YELLOW}Skipping SSH key setup. You can run 'create-keys' or 'copy-keys' manually later.${NC}"
fi

# ── Step 6: Build and switch ─────────────────────────────────────────────────
_step "Step 6/6 — Build and activate nix-darwin configuration"
_print "This will build the full system configuration and activate it (may take a while)…"
export NIXPKGS_ALLOW_UNFREE=1
nix --extra-experimental-features 'nix-command flakes' run ".#build-switch"

_print "\n${GREEN}Bootstrap complete! Please restart your terminal (or open a new one) to pick up all changes.${NC}"
